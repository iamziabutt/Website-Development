<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FalseTagt</title>
</head>
<body>
    <h2>JavaScript Functions</h2>
    <p>Do a calculaton and display the result.</p>
    <p id="Banana"></p>
    <script>
        function add(a, b) {
            return a + b;
        }
        function average(a, b) {
            return add(a, b) / 2;
        }
        let result = average(10, 20);
        document.getElementById("Banana").innerHTML = result;
    </script>
</body>
</html>
