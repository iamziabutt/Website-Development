<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Argument</title>
</head>
<body>
    <p>Find the largest number</p>
    <p id="result"></p>
    <script>
        function Findmax(){
            var i;
            var max=0
            for(i=0;i<arguments.length;i++){
                if(arguments[i]>max){
                    max=arguments[i];
                }
            }
            return max;
        }
        document.getElementById("result").innerHTML=Findmax(2,3,5);
    </script>
</body>
</html>
